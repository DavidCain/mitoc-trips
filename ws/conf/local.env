# This file is not shell, but Docker `env-file` syntax.
# shellcheck disable=SC2034
WS_MODE=local

ENV_VAR_SOURCED=1

# If changing these, set the `compose.yml` values as well!
DATABASE_HOST=localhost
DATABASE_NAME=ws
DATABASE_PORT=5432

# Miscellaneous settings that are fine as plaintext settings
DJANGO_ALLOWED_HOST=localhost
BURSAR_NAME=Bursar
DOCUSIGN_API_BASE=https://demo.docusign.net/restapi/v2/
DOCUSIGN_WAIVER_TEMPLATE_ID=template-uuid

# Legacy disk-based logging (to be replaced with CloudWatch)
WS_LOTTERY_LOG_DIR=/tmp/
DJANGO_LOG_FILE=/tmp/django.log

# Actually sensitive values
DATABASE_USER=ws
DATABASE_PASSWORD=password
DJANGO_SECRET_KEY=this-is-obviously-not-secure-only-use-it-locally
DOCUSIGN_INTEGRATOR_KEY=secret-uuid
DOCUSIGN_PASSWORD=super-secret
DOCUSIGN_USERNAME=djcain@mit.edu
GEARDB_SECRET_KEY=secret-shared-with-the-mitoc-gear-repo
MEMBERSHIP_SECRET_KEY=secret-shared-with-the,mitoc-aws-repo-which-is-ideally-at-least-64-bytes-for-use-with-SHA512
PRNG_SEED_SECRET=some-key-unknown-to-participants
SENTRY_DSN=
UNSUBSCRIBE_SECRET_KEY=secret-used-only-for-unsubscribe-tokens

# Legacy AMQP-based Celery backend
CELERY_BROKER_URL=amqp://guest:guest@127.0.0.1//
